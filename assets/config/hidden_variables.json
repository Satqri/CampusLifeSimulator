  "patterns": [
    {
      "pattern": "prefix_suffix",
      "prefix": "_event_",
      "suffix": "_count",
      "min": 0,
      "max": 99,
      "merge": "accumulate",
      "scaling": "none"
    },
    {
      "pattern": "prefix_suffix",
      "prefix": "_event_",
      "suffix": "_last_day",
      "min": -1,
      "max": 14,
      "merge": "assign",
      "scaling": "none"
    },
    {
      "pattern": "suffix",
      "suffix": "Count",
      "min": 0,
      "max": 99,
      "merge": "accumulate",
      "scaling": "none"
    }
