{
  "events": [
    {
      "id": "friend_help_start",
      "trigger": { "type": "interaction", "action_id": "library_desk", "once": true,
        "conditions": [
          { "kind": "group", "require": "any", "conditions": [
            { "kind": "stat", "stat": "friendStage", "op": "eq", "value": 0 },
            { "kind": "stat", "stat": "friendStage", "op": "eq", "value": false }
          ] }
        ],
        "require": "all"
      },
      "root": "intro",
      "steps": {
        "intro": {
          "type": "display",
          "title": "同学卡题求助",
          "body": "你在图书馆或教室复习时，一个同学拿着题目凑过来：'这题你会吗？我卡半天了。' 你自己的计划也很满，但他看起来真的需要帮助。",
          "then": "decide"
        },
        "decide": {
          "type": "choice",
          "title": "同学求助",
          "body": "怎么回应？",
          "options": [
            { "text": "耐心讲到他听懂", "then": "patient_check" },
            { "text": "给关键提示，让他自己想", "then": "hint_check" },
            { "text": "推荐他去问老师", "then": "recommend_teacher" },
            { "text": "说自己也很忙", "then": "refuse" }
          ]
        },
        "patient_check": {
          "type": "check",
          "conditions": [
            { "kind": "stat", "stat": "academic", "op": ">=", "value": 50 },
            { "kind": "stat", "stat": "energy", "op": ">=", "value": 30 }
          ],
          "require": "all",
          "title": "耐心讲解",
          "body": "你放下手头的事，一步步给他讲思路...",
          "then": "patient_success",
          "else": "patient_fail"
        },
        "patient_success": {
          "type": "outcome",
          "title": "讲懂了",
          "body": "你花了不少时间把思路讲清楚。对方明显松了一口气，也认真记住了你这次帮忙。",
          "delta": { "academic": 2, "social": 5, "energy": -8 },
          "hidden_delta": { "friendBond": 2, "friendHelpCount": 1, "friendStage": 1 }
        },
        "patient_fail": {
          "type": "outcome",
          "title": "讲不明白",
          "body": "你试着讲了几次，但对方还是不太明白。气氛有点尴尬。",
          "delta": { "san": 5, "energy": -8 },
          "hidden_delta": { "friendBond": -1, "friendHelpCount": 1, "friendStage": 1 }
        },
        "hint_check": {
          "type": "check",
          "conditions": [
            { "kind": "stat", "stat": "academic", "op": ">=", "value": 30 }
          ],
          "require": "all",
          "title": "给关键提示",
          "body": "你扫了一眼题目，点在关键步骤上说了几句...",
          "then": "hint_success",
          "else": "hint_fail"
        },
        "hint_success": {
          "type": "outcome",
          "title": "点到为止",
          "body": "你没有直接给答案，而是点出关键思路。对方想了一会儿，终于有点明白了。",
          "delta": { "academic": 1, "social": 3, "energy": -3 },
          "hidden_delta": { "friendBond": 1, "friendHelpCount": 1, "friendStage": 1 }
        },
        "hint_fail": {
          "type": "outcome",
          "title": "提示不够",
          "body": "你的提示太简略了，对方听完还是一脸茫然。",
          "delta": { "san": 2, "energy": -3 },
          "hidden_delta": { "friendHelpCount": 1, "friendStage": 1 }
        },
        "recommend_teacher": {
          "type": "outcome",
          "title": "推荐去问老师",
          "body": "你没有硬讲，而是建议他去问老师。这个做法稳妥，但关系没有明显拉近。",
          "delta": {},
          "hidden_delta": { "teacherTrust": 1, "friendStage": 1 }
        },
        "refuse": {
          "type": "outcome",
          "title": "说自己很忙",
          "body": "你婉拒了他。对方点点头离开，气氛有一点尴尬。",
          "delta": { "san": -2 },
          "hidden_delta": { "friendBond": -1, "friendRefuseCount": 1, "friendStage": 1 }
        }
      }
    },
    {
      "id": "friend_lunch_return",
      "trigger": { "type": "interaction", "action_id": "cafeteria_table", "once": true,
        "conditions": [
          { "kind": "stat", "stat": "friendStage", "op": "eq", "value": 1 },
          { "kind": "stat", "stat": "friendHelpCount", "op": ">=", "value": 1 }
        ],
        "require": "all"
      },
      "root": "intro",
      "steps": {
        "intro": {
          "type": "display",
          "title": "食堂回礼",
          "body": "午饭时，之前被你帮过的同学端着餐盘坐到你旁边，说上次那题终于弄懂了，想请你喝饮料。",
          "then": "decide"
        },
        "decide": {
          "type": "choice",
          "title": "食堂回礼",
          "body": "你怎么回应？",
          "options": [
            { "text": "接受回礼，顺便聊天", "then": "accept_chat_check" },
            { "text": "不收饮料，但继续聊", "then": "refuse_drink_check" },
            { "text": "只简单回应", "then": "brief_reply" },
            { "text": "开玩笑说以后帮你点名", "then": "joke_roll_call_check" }
          ]
        },
        "accept_chat_check": {
          "type": "check",
          "conditions": [
            { "kind": "stat", "stat": "social", "op": ">=", "value": 30 }
          ],
          "require": "all",
          "then": "accept_chat_success",
          "else": "accept_chat_fail"
        },
        "accept_chat_success": {
          "type": "outcome",
          "title": "边吃边聊",
          "body": "你接过饮料，自然地和他聊起了各自的近况。关系自然熟了一点。",
          "delta": { "social": 2, "san": -3, "energy": 5 },
          "hidden_delta": { "friendBond": 1, "friendStage": 2 }
        },
        "accept_chat_fail": {
          "type": "outcome",
          "title": "聊天尴尬",
          "body": "你想聊点什么，但话题总是接不上。气氛有些干。",
          "delta": { "san": 2, "energy": 3 },
          "hidden_delta": { "friendStage": 2 }
        },
        "refuse_drink_check": {
          "type": "check",
          "conditions": [
            { "kind": "stat", "stat": "san", "op": "<", "value": 60 }
          ],
          "require": "any",
          "then": "refuse_drink_success",
          "else": "refuse_drink_fail"
        },
        "refuse_drink_success": {
          "type": "outcome",
          "title": "不收但继续聊",
          "body": "你笑着把饮料推了回去，对方反而觉得你更靠谱了。",
          "delta": { "social": 1, "san": -2 },
          "hidden_delta": { "friendBond": 1, "owedFavor": true, "friendStage": 2 }
        },
        "refuse_drink_fail": {
          "type": "outcome",
          "title": "推辞过度",
          "body": "你推辞得太坚决，对方有点尴尬地收回了饮料。",
          "delta": { "san": 3 },
          "hidden_delta": { "friendStage": 2 }
        },
        "brief_reply": {
          "type": "outcome",
          "title": "简单回应",
          "body": "你礼貌回应了几句，然后继续吃饭。关系没有变差，也没有更近。",
          "delta": {},
          "hidden_delta": { "friendStage": 2 }
        },
        "joke_roll_call_check": {
          "type": "check",
          "conditions": [
            { "kind": "stat", "stat": "social", "op": ">=", "value": 40 }
          ],
          "require": "all",
          "then": "joke_roll_call_success",
          "else": "joke_roll_call_fail"
        },
        "joke_roll_call_success": {
          "type": "outcome",
          "title": "开玩笑",
          "body": "你开玩笑道：'那以后老师点名的时候，你帮我应一声呗。' 对方笑了：'行啊，到时候看我发挥。' 这句话也许真的会派上用场。",
          "delta": { "social": 2, "academic": -1 },
          "hidden_delta": { "friendBond": 1, "friendStage": 2 }
        },
        "joke_roll_call_fail": {
          "type": "outcome",
          "title": "玩笑没响",
          "body": "你的玩笑没有收获预想的效果。对方只是礼貌地笑了笑。",
          "delta": { "san": 2 },
          "hidden_delta": { "friendStage": 2 }
        }
      }
    },
    {
      "id": "friend_roll_call_help",
      "trigger": { "type": "time_schedule", "method": "crossed_class_time", "once": true,
        "conditions": [
          { "kind": "location", "place": "classroom", "op": "neq" },
          { "kind": "stat", "stat": "friendStage", "op": ">=", "value": 2 },
          { "kind": "stat", "stat": "friendBond", "op": ">=", "value": 2 },
          { "kind": "stat", "stat": "friendHelpCount", "op": ">=", "value": 1 }
        ],
        "require": "all"
      },
      "root": "intro",
      "steps": {
        "intro": {
          "type": "display",
          "title": "点名救场",
          "body": "你逃课时，老师突然点名。手机震了一下，是那个同学发来的消息：'老师点到你了，要不要我帮你圆一下？'",
          "then": "decide"
        },
        "decide": {
          "type": "choice",
          "title": "点名救场",
          "body": "怎么回复？",
          "options": [
            { "text": "拜托他帮忙圆场", "then": "ask_cover_check" },
            { "text": "立刻赶回教室", "then": "rush_back_check2" },
            { "text": "让他别管", "then": "dont_cover_check" },
            { "text": "已读不回", "then": "ignore_message" }
          ]
        },
        "ask_cover_check": {
          "type": "check",
          "conditions": [
            { "kind": "stat", "stat": "social", "op": ">=", "value": 40 }
          ],
          "require": "any",
          "title": "拜托帮忙",
          "body": "你快速回复：'拜托了！帮我应一下！'",
          "then": "cover_success",
          "else": "cover_fail"
        },
        "cover_success": {
          "type": "outcome",
          "title": "救场成功",
          "body": "他帮你应付了过去。你躲过一劫，但这份人情以后肯定要还。",
          "delta": { "san": 5 },
          "hidden_delta": { "rollCallSavedCount": 1, "friendRollCallHelpCount": 1, "owedFavor": true, "friendStage": 3 }
        },
        "cover_fail": {
          "type": "outcome",
          "title": "救场失败",
          "body": "同学没能帮你圆过去。老师停顿了一下，在名单上做了标记。",
          "delta": { "san": 8 },
          "hidden_delta": { "absencePenaltyCount": 1, "teacherTrust": -5, "friendStage": 3 }
        },
        "rush_back_check2": {
          "type": "check",
          "conditions": [
            { "kind": "stat", "stat": "energy", "op": ">=", "value": 40 }
          ],
          "require": "all",
          "title": "赶回教室",
          "body": "你回复：'不用，我马上到！' 然后拔腿就跑...",
          "then": "rush_back_success2",
          "else": "rush_back_fail2"
        },
        "rush_back_success2": {
          "type": "outcome",
          "title": "自己冲回去",
          "body": "你没有让他冒险，而是自己冲回教室。虽然狼狈，但还算体面。",
          "delta": { "energy": -15, "san": 5 },
          "hidden_delta": { "lateCount": 1, "returnClassCount": 1, "rollCallSavedCount": 1, "classAttendCount": 1, "teacherTrust": 2, "friendStage": 3 }
        },
        "rush_back_fail2": {
          "type": "outcome",
          "title": "体力不支",
          "body": "你实在没体力跑回教室了。只好回复他不要管了。",
          "delta": { "san": 8 },
          "hidden_delta": { "skipClassCount": 1, "absencePenaltyCount": 1, "teacherTrust": -5, "friendStage": 3 }
        },
        "dont_cover_check": {
          "type": "check",
          "conditions": [
            { "kind": "stat", "stat": "san", "op": "<", "value": 70 }
          ],
          "require": "all",
          "then": "dont_cover_success",
          "else": "dont_cover_fail"
        },
        "dont_cover_success": {
          "type": "outcome",
          "title": "不让他冒险",
          "body": "你回复：'别管了，反正我不会少块肉。' 对方记住了你的分寸。",
          "delta": { "san": 8 },
          "hidden_delta": { "skipClassCount": 1, "absencePenaltyCount": 1, "friendBond": 1, "friendStage": 3 }
        },
        "dont_cover_fail": {
          "type": "outcome",
          "title": "心态崩了",
          "body": "你想回复让他别管，但手指一直在发抖。没等你想好，老师已经记了缺勤。",
          "delta": { "san": 12 },
          "hidden_delta": { "skipClassCount": 1, "absencePenaltyCount": 1, "friendStage": 3 }
        },
        "ignore_message": {
          "type": "outcome",
          "title": "已读不回",
          "body": "你看着消息，没有回复。老师记了你缺勤，同学也不知道你到底怎么想。",
          "delta": { "san": 2 },
          "hidden_delta": { "skipClassCount": 1, "absencePenaltyCount": 1, "friendBond": -1, "friendRefuseCount": 1, "friendStage": 3 }
        }
      }
    },
    {
      "id": "friend_exam_review",
      "trigger": { "type": "interaction", "action_id": "library_desk", "once": true,
        "conditions": [
          { "kind": "stat", "stat": "friendStage", "op": ">=", "value": 2 },
          { "kind": "stat", "stat": "friendBond", "op": ">=", "value": 3 }
        ],
        "require": "all"
      },
      "root": "intro",
      "steps": {
        "intro": {
          "type": "display",
          "title": "考前互助复习",
          "body": "考试前一晚，你收到同学发来的复习资料。他说：'之前你帮过我，这次我整理了一份重点，要不要一起过一遍？'",
          "then": "decide"
        },
        "decide": {
          "type": "choice",
          "title": "考前互助",
          "body": "怎么回应？",
          "options": [
            { "text": "一起复习重点", "then": "review_together_check" },
            { "text": "让他讲你不会的部分", "then": "let_him_teach_check" },
            { "text": "把自己的笔记也分享给他", "then": "share_notes_check" },
            { "text": "拒绝，自己复习", "then": "refuse_review" }
          ]
        },
        "review_together_check": {
          "type": "check",
          "conditions": [
            { "kind": "stat", "stat": "academic", "op": ">=", "value": 40 }
          ],
          "require": "any",
          "then": "review_together_success",
          "else": "review_together_fail"
        },
        "review_together_success": {
          "type": "outcome",
          "title": "一起复习",
          "body": "你们把重点过了一遍。很多零散知识终于串起来了。",
          "delta": { "academic": 10, "san": -5, "energy": -10 },
          "hidden_delta": { "sharedNotes": true, "friendReviewCount": 1, "friendHelpCount": 1, "friendStage": 4 }
        },
        "review_together_fail": {
          "type": "outcome",
          "title": "跟不上",
          "body": "你试着跟上他的节奏，但很多地方你都听不懂。",
          "delta": { "san": 3, "energy": -8 },
          "hidden_delta": { "friendReviewCount": 1, "friendStage": 4 }
        },
        "let_him_teach_check": {
          "type": "check",
          "conditions": [
            { "kind": "stat", "stat": "social", "op": ">=", "value": 40 }
          ],
          "require": "all",
          "then": "let_him_teach_success",
          "else": "let_him_teach_fail"
        },
        "let_him_teach_success": {
          "type": "outcome",
          "title": "他讲你听",
          "body": "他把几个难点讲得很细，你突然理解了之前一直卡住的内容。",
          "delta": { "academic": 8, "social": 5, "energy": -8 },
          "hidden_delta": { "friendBond": 1, "friendReviewCount": 1, "friendStage": 4 }
        },
        "let_him_teach_fail": {
          "type": "outcome",
          "title": "讲不清楚",
          "body": "他试着讲，但有些地方他自己也讲不太清楚。",
          "delta": { "san": 3, "energy": -8 },
          "hidden_delta": { "friendReviewCount": 1, "friendStage": 4 }
        },
        "share_notes_check": {
          "type": "check",
          "conditions": [
            { "kind": "stat", "stat": "academic", "op": ">=", "value": 50 }
          ],
          "require": "all",
          "then": "share_notes_success",
          "else": "share_notes_fail"
        },
        "share_notes_success": {
          "type": "outcome",
          "title": "交换笔记",
          "body": "你们交换了笔记，像临时组成了一个考前互助小组。",
          "delta": { "academic": 5, "social": 3, "energy": -5 },
          "hidden_delta": { "sharedNotes": true, "friendBond": 1, "friendReviewCount": 1, "friendStage": 4 }
        },
        "share_notes_fail": {
          "type": "outcome",
          "title": "笔记太乱",
          "body": "你翻了翻自己的笔记，发现记得太乱，不好意思发给他。",
          "delta": { "san": 2 },
          "hidden_delta": { "friendReviewCount": 1, "friendStage": 4 }
        },
        "refuse_review": {
          "type": "outcome",
          "title": "自己复习",
          "body": "你决定按自己的节奏复习。安静是安静，但少了一份帮助。",
          "delta": { "academic": 5, "energy": -5 },
          "hidden_delta": { "friendRefuseCount": 1, "friendStage": 4 }
        }
      }
    }
  ]
}
