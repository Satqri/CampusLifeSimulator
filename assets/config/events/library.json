{
  "events": [
    {
      "id": "library_seat_battle",
      "trigger": {
        "type": "interaction",
        "action_id": "library_desk",
        "chance": 20,
        "once": true,
        "fallback_to_regular": true,
        "conditions": [
          {
            "kind": "group",
            "require": "any",
            "conditions": [
              {
                "kind": "time",
                "stat": "phase",
                "op": "eq",
                "value": "afternoon"
              },
              {
                "kind": "time",
                "stat": "phase",
                "op": "eq",
                "value": "evening"
              }
            ]
          }
        ],
        "require": "all"
      },
      "root": "intro",
      "steps": {
        "intro": {
          "type": "display",
          "then": "decide",
          "title_key": "event.library_seat_battle.intro.title",
          "body_key": "event.library_seat_battle.intro.body"
        },
        "decide": {
          "type": "choice",
          "options": [
            {
              "then": "rush_check",
              "text_key": "event.library_seat_battle.decide.option1"
            },
            {
              "then": "polite_check",
              "text_key": "event.library_seat_battle.decide.option2"
            },
            {
              "then": "corner_check",
              "text_key": "event.library_seat_battle.decide.option3"
            },
            {
              "then": "give_up",
              "text_key": "event.library_seat_battle.decide.option4"
            }
          ],
          "title_key": "event.library_seat_battle.decide.title",
          "body_key": "event.library_seat_battle.decide.body"
        },
        "rush_check": {
          "type": "check",
          "conditions": [
            {
              "kind": "stat",
              "stat": "energy",
              "op": ">=",
              "value": 40
            }
          ],
          "require": "all",
          "then": "rush_success",
          "else": "rush_fail"
        },
        "rush_success": {
          "type": "outcome",
          "delta": {
            "academic": 5,
            "san": 2,
            "energy": -5,
            "social": -5
          },
          "title_key": "event.library_seat_battle.rush_success.title",
          "body_key": "event.library_seat_battle.rush_success.body"
        },
        "rush_fail": {
          "type": "outcome",
          "delta": {
            "san": 5,
            "energy": -3
          },
          "title_key": "event.library_seat_battle.rush_fail.title",
          "body_key": "event.library_seat_battle.rush_fail.body"
        },
        "polite_check": {
          "type": "check",
          "conditions": [
            {
              "kind": "stat",
              "stat": "social",
              "op": ">=",
              "value": 40
            }
          ],
          "require": "all",
          "then": "polite_success",
          "else": "polite_fail"
        },
        "polite_success": {
          "type": "outcome",
          "delta": {
            "academic": 5,
            "social": 5,
            "energy": -2
          },
          "hidden_delta": {
            "friendBond": 1
          },
          "title_key": "event.library_seat_battle.polite_success.title",
          "body_key": "event.library_seat_battle.polite_success.body"
        },
        "polite_fail": {
          "type": "outcome",
          "delta": {
            "san": 5,
            "energy": -3
          },
          "title_key": "event.library_seat_battle.polite_fail.title",
          "body_key": "event.library_seat_battle.polite_fail.body"
        },
        "corner_check": {
          "type": "check",
          "conditions": [
            {
              "kind": "stat",
              "stat": "academic",
              "op": ">=",
              "value": 30
            }
          ],
          "require": "all",
          "then": "corner_success",
          "else": "corner_fail"
        },
        "corner_success": {
          "type": "outcome",
          "delta": {
            "academic": 8,
            "energy": -5
          },
          "title_key": "event.library_seat_battle.corner_success.title",
          "body_key": "event.library_seat_battle.corner_success.body"
        },
        "corner_fail": {
          "type": "outcome",
          "delta": {
            "san": 5
          },
          "title_key": "event.library_seat_battle.corner_fail.title",
          "body_key": "event.library_seat_battle.corner_fail.body"
        },
        "give_up": {
          "type": "outcome",
          "delta": {
            "san": 5
          },
          "title_key": "event.library_seat_battle.give_up.title",
          "body_key": "event.library_seat_battle.give_up.body"
        }
      }
    }
  ]
}
