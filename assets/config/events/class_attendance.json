{
  "events": [
    {
      "id": "class_attendance",
      "trigger": {
        "type": "time_schedule",
        "method": "crossed_class_time"
      },
      "root": "check_location",
      "steps": {
        "check_location": {
          "type": "check",
          "conditions": [
            {
              "kind": "location",
              "place": "classroom"
            }
          ],
          "require": "all",
          "then": "attend_normal",
          "else": "risk_check"
        },
        "attend_normal": {
          "type": "outcome",
          "delta": {
            "academic": 10,
            "energy": -10
          },
          "hidden_delta": {
            "classAttendCount": 1,
            "teacherTrust": 2
          },
          "time_advance": 45,
          "title_key": "event.class_attendance.attend_normal.title",
          "body_key": "event.class_attendance.attend_normal.body"
        },
        "risk_check": {
          "type": "check",
          "conditions": [
            {
              "kind": "stat",
              "stat": "skipClassCount",
              "op": ">=",
              "value": 1
            },
            {
              "kind": "stat",
              "stat": "teacherTrust",
              "op": "<",
              "value": 0
            }
          ],
          "require": "any",
          "then": "roll_call_high_risk",
          "else": "roll_call",
          "title_key": "event.class_attendance.risk_check.title",
          "body_key": "event.class_attendance.risk_check.body"
        },
        "roll_call": {
          "type": "random_check",
          "probability": 30,
          "success": "roll_call_caught",
          "failure": "skip_success",
          "time_advance": 90,
          "title_key": "event.class_attendance.roll_call.title",
          "body_key": "event.class_attendance.roll_call.body",
          "flash_key": "event.class_attendance.roll_call.flash"
        },
        "roll_call_high_risk": {
          "type": "random_check",
          "probability": 45,
          "success": "roll_call_caught",
          "failure": "skip_success",
          "time_advance": 90,
          "title_key": "event.class_attendance.roll_call_high_risk.title",
          "body_key": "event.class_attendance.roll_call_high_risk.body",
          "flash_key": "event.class_attendance.roll_call.flash"
        },
        "skip_success": {
          "type": "outcome",
          "delta": {
            "san": 5
          },
          "hidden_delta": {
            "skipClassCount": 1,
            "teacherTrust": -2
          },
          "title_key": "event.class_attendance.skip_success.title",
          "body_key": "event.class_attendance.skip_success.body"
        },
        "roll_call_caught": {
          "type": "choice",
          "options": [
            {
              "then": "friend_cover_check",
              "text_key": "event.class_attendance.roll_call_caught.option1"
            },
            {
              "then": "rush_back_check",
              "text_key": "event.class_attendance.roll_call_caught.option2"
            },
            {
              "then": "ignore_roll_call",
              "text_key": "event.class_attendance.roll_call_caught.option3"
            }
          ],
          "title_key": "event.class_attendance.roll_call_caught.title",
          "body_key": "event.class_attendance.roll_call_caught.body"
        },
        "friend_cover_check": {
          "type": "check",
          "conditions": [
            {
              "kind": "stat",
              "stat": "social",
              "op": ">=",
              "value": 40
            }
          ],
          "require": "any",
          "then": "friend_cover_success",
          "else": "friend_cover_fail",
          "title_key": "event.class_attendance.friend_cover_check.title",
          "body_key": "event.class_attendance.friend_cover_check.body"
        },
        "friend_cover_success": {
          "type": "outcome",
          "delta": {
            "san": -5
          },
          "hidden_delta": {
            "rollCallCount": 1,
            "rollCallSavedCount": 1,
            "owedFavor": true
          },
          "title_key": "event.class_attendance.friend_cover_success.title",
          "body_key": "event.class_attendance.friend_cover_success.body"
        },
        "friend_cover_fail": {
          "type": "outcome",
          "delta": {
            "san": -8
          },
          "hidden_delta": {
            "rollCallCount": 1,
            "teacherTrust": -2
          },
          "title_key": "event.class_attendance.friend_cover_fail.title",
          "body_key": "event.class_attendance.friend_cover_fail.body"
        },
        "rush_back_check": {
          "type": "check",
          "conditions": [
            {
              "kind": "stat",
              "stat": "energy",
              "op": ">=",
              "value": 40
            }
          ],
          "require": "all",
          "then": "rush_back_success",
          "else": "rush_back_fail",
          "title_key": "event.class_attendance.rush_back_check.title",
          "body_key": "event.class_attendance.rush_back_check.body"
        },
        "rush_back_success": {
          "type": "outcome",
          "delta": {
            "energy": -15,
            "san": -5
          },
          "hidden_delta": {
            "lateCount": 1,
            "returnClassCount": 1,
            "rollCallSavedCount": 1,
            "classAttendCount": 1,
            "teacherTrust": 2
          },
          "title_key": "event.class_attendance.rush_back_success.title",
          "body_key": "event.class_attendance.rush_back_success.body"
        },
        "rush_back_fail": {
          "type": "outcome",
          "delta": {
            "san": -8
          },
          "hidden_delta": {
            "skipClassCount": 1,
            "absencePenaltyCount": 1,
            "teacherTrust": -5
          },
          "title_key": "event.class_attendance.rush_back_fail.title",
          "body_key": "event.class_attendance.rush_back_fail.body"
        },
        "ignore_roll_call": {
          "type": "outcome",
          "delta": {
            "san": -8
          },
          "hidden_delta": {
            "rollCallCount": 1,
            "skipClassCount": 1,
            "absencePenaltyCount": 1,
            "teacherTrust": -5
          },
          "title_key": "event.class_attendance.ignore_roll_call.title",
          "body_key": "event.class_attendance.ignore_roll_call.body"
        }
      }
    }
  ]
}
