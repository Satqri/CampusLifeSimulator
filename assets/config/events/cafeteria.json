{
  "events": [
    {
      "id": "cafeteria_last_chicken",
      "trigger": {
        "type": "interaction",
        "action_id": "cafeteria_counter",
        "chance": 25,
        "once": true,
        "fallback_to_regular": true,
        "conditions": [
          {
            "kind": "time",
            "stat": "meal_time",
            "op": "eq",
            "value": true
          }
        ],
        "require": "all"
      },
      "root": "intro",
      "steps": {
        "intro": {
          "type": "display",
          "then": "decide",
          "title_key": "event.cafeteria_last_chicken.intro.title",
          "body_key": "event.cafeteria_last_chicken.intro.body"
        },
        "decide": {
          "type": "choice",
          "options": [
            {
              "then": "snatch_check",
              "text_key": "event.cafeteria_last_chicken.decide.option1"
            },
            {
              "then": "share_check",
              "text_key": "event.cafeteria_last_chicken.decide.option2"
            },
            {
              "then": "luxury_check",
              "text_key": "event.cafeteria_last_chicken.decide.option3"
            },
            {
              "then": "veggie",
              "text_key": "event.cafeteria_last_chicken.decide.option4"
            }
          ],
          "title_key": "event.cafeteria_last_chicken.decide.title",
          "body_key": "event.cafeteria_last_chicken.decide.body"
        },
        "snatch_check": {
          "type": "check",
          "conditions": [
            {
              "kind": "stat",
              "stat": "energy",
              "op": ">=",
              "value": 50
            }
          ],
          "require": "all",
          "then": "snatch_success",
          "else": "snatch_fail"
        },
        "snatch_success": {
          "type": "outcome",
          "delta": {
            "energy": 10,
            "san": -5
          },
          "title_key": "event.cafeteria_last_chicken.snatch_success.title",
          "body_key": "event.cafeteria_last_chicken.snatch_success.body"
        },
        "snatch_fail": {
          "type": "outcome",
          "delta": {
            "energy": 2,
            "san": 2
          },
          "title_key": "event.cafeteria_last_chicken.snatch_fail.title",
          "body_key": "event.cafeteria_last_chicken.snatch_fail.body"
        },
        "share_check": {
          "type": "check",
          "conditions": [
            {
              "kind": "stat",
              "stat": "social",
              "op": ">=",
              "value": 40
            }
          ],
          "require": "all",
          "then": "share_success",
          "else": "share_fail"
        },
        "share_success": {
          "type": "outcome",
          "delta": {
            "energy": 5,
            "social": 5
          },
          "hidden_delta": {
            "friendBond": 1,
            "mealCount": 1
          },
          "title_key": "event.cafeteria_last_chicken.share_success.title",
          "body_key": "event.cafeteria_last_chicken.share_success.body"
        },
        "share_fail": {
          "type": "outcome",
          "delta": {
            "energy": 2,
            "san": 2
          },
          "title_key": "event.cafeteria_last_chicken.share_fail.title",
          "body_key": "event.cafeteria_last_chicken.share_fail.body"
        },
        "luxury_check": {
          "type": "check",
          "conditions": [
            {
              "kind": "stat",
              "stat": "gold",
              "op": ">=",
              "value": 30
            }
          ],
          "require": "all",
          "then": "luxury_success",
          "else": "luxury_fail"
        },
        "luxury_success": {
          "type": "outcome",
          "delta": {
            "gold": -30,
            "energy": 15,
            "san": -10
          },
          "title_key": "event.cafeteria_last_chicken.luxury_success.title",
          "body_key": "event.cafeteria_last_chicken.luxury_success.body"
        },
        "luxury_fail": {
          "type": "outcome",
          "delta": {
            "energy": 2,
            "san": 2
          },
          "title_key": "event.cafeteria_last_chicken.luxury_fail.title",
          "body_key": "event.cafeteria_last_chicken.luxury_fail.body"
        },
        "veggie": {
          "type": "outcome",
          "delta": {
            "energy": 2,
            "san": 2
          },
          "title_key": "event.cafeteria_last_chicken.veggie.title",
          "body_key": "event.cafeteria_last_chicken.veggie.body"
        }
      }
    }
  ]
}
