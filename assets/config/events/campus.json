{
  "events": [
    {
      "id": "campus_roadshow",
      "trigger": {
        "type": "interaction",
        "action_id": "campus_square",
        "chance": 18,
        "once": true,
        "fallback_to_regular": true,
        "conditions": [
          {
            "kind": "group",
            "require": "any",
            "conditions": [
              {
                "kind": "time",
                "stat": "phase",
                "op": "eq",
                "value": "noon"
              },
              {
                "kind": "time",
                "stat": "phase",
                "op": "eq",
                "value": "afternoon"
              },
              {
                "kind": "time",
                "stat": "phase",
                "op": "eq",
                "value": "evening"
              }
            ]
          }
        ],
        "require": "all"
      },
      "root": "intro",
      "steps": {
        "intro": {
          "type": "display",
          "then": "decide",
          "title_key": "event.campus_roadshow.intro.title",
          "body_key": "event.campus_roadshow.intro.body"
        },
        "decide": {
          "type": "choice",
          "options": [
            {
              "then": "go_up_check",
              "text_key": "event.campus_roadshow.decide.option1"
            },
            {
              "then": "humor_check",
              "text_key": "event.campus_roadshow.decide.option2"
            },
            {
              "then": "escape_check",
              "text_key": "event.campus_roadshow.decide.option3"
            },
            {
              "then": "embarrassed",
              "text_key": "event.campus_roadshow.decide.option4"
            }
          ],
          "title_key": "event.campus_roadshow.decide.title",
          "body_key": "event.campus_roadshow.decide.body"
        },
        "go_up_check": {
          "type": "check",
          "conditions": [
            {
              "kind": "stat",
              "stat": "social",
              "op": ">=",
              "value": 50
            }
          ],
          "require": "all",
          "then": "go_up_success",
          "else": "go_up_fail"
        },
        "go_up_success": {
          "type": "outcome",
          "delta": {
            "social": 10,
            "san": -5,
            "energy": -5
          },
          "title_key": "event.campus_roadshow.go_up_success.title",
          "body_key": "event.campus_roadshow.go_up_success.body"
        },
        "go_up_fail": {
          "type": "outcome",
          "delta": {
            "social": -3,
            "san": 10,
            "energy": -5
          },
          "title_key": "event.campus_roadshow.go_up_fail.title",
          "body_key": "event.campus_roadshow.go_up_fail.body"
        },
        "humor_check": {
          "type": "check",
          "conditions": [
            {
              "kind": "stat",
              "stat": "social",
              "op": ">=",
              "value": 60
            }
          ],
          "require": "all",
          "then": "humor_success",
          "else": "humor_fail"
        },
        "humor_success": {
          "type": "outcome",
          "delta": {
            "social": 15,
            "energy": -5
          },
          "title_key": "event.campus_roadshow.humor_success.title",
          "body_key": "event.campus_roadshow.humor_success.body"
        },
        "humor_fail": {
          "type": "outcome",
          "delta": {
            "san": 5,
            "energy": -3
          },
          "title_key": "event.campus_roadshow.humor_fail.title",
          "body_key": "event.campus_roadshow.humor_fail.body"
        },
        "escape_check": {
          "type": "check",
          "conditions": [
            {
              "kind": "stat",
              "stat": "energy",
              "op": ">=",
              "value": 40
            }
          ],
          "require": "all",
          "then": "escape_success",
          "else": "escape_fail"
        },
        "escape_success": {
          "type": "outcome",
          "delta": {
            "energy": -10,
            "san": 2
          },
          "title_key": "event.campus_roadshow.escape_success.title",
          "body_key": "event.campus_roadshow.escape_success.body"
        },
        "escape_fail": {
          "type": "outcome",
          "delta": {
            "san": 3,
            "energy": -3
          },
          "title_key": "event.campus_roadshow.escape_fail.title",
          "body_key": "event.campus_roadshow.escape_fail.body"
        },
        "embarrassed": {
          "type": "outcome",
          "delta": {
            "san": 10,
            "energy": -2
          },
          "title_key": "event.campus_roadshow.embarrassed.title",
          "body_key": "event.campus_roadshow.embarrassed.body"
        }
      }
    }
  ]
}
