{
  "events": [
    {
      "id": "gym_equipment_occupied",
      "trigger": {
        "type": "interaction",
        "action_id": "gym_bench",
        "chance": 18,
        "once": true,
        "fallback_to_regular": true,
        "conditions": [
          {
            "kind": "group",
            "require": "any",
            "conditions": [
              {
                "kind": "time",
                "stat": "phase",
                "op": "eq",
                "value": "afternoon"
              },
              {
                "kind": "time",
                "stat": "phase",
                "op": "eq",
                "value": "evening"
              }
            ]
          }
        ],
        "require": "all"
      },
      "root": "intro",
      "steps": {
        "intro": {
          "type": "display",
          "then": "decide",
          "title_key": "event.gym_equipment_occupied.intro.title",
          "body_key": "event.gym_equipment_occupied.intro.body"
        },
        "decide": {
          "type": "choice",
          "options": [
            {
              "then": "ask_check",
              "text_key": "event.gym_equipment_occupied.decide.option1"
            },
            {
              "then": "change_check",
              "text_key": "event.gym_equipment_occupied.decide.option2"
            },
            {
              "then": "wait",
              "text_key": "event.gym_equipment_occupied.decide.option3"
            },
            {
              "then": "leave",
              "text_key": "event.gym_equipment_occupied.decide.option4"
            }
          ],
          "title_key": "event.gym_equipment_occupied.decide.title",
          "body_key": "event.gym_equipment_occupied.decide.body"
        },
        "ask_check": {
          "type": "check",
          "conditions": [
            {
              "kind": "stat",
              "stat": "social",
              "op": ">=",
              "value": 40
            }
          ],
          "require": "all",
          "then": "ask_success",
          "else": "ask_fail"
        },
        "ask_success": {
          "type": "outcome",
          "delta": {
            "energy": -2,
            "social": 3
          },
          "title_key": "event.gym_equipment_occupied.ask_success.title",
          "body_key": "event.gym_equipment_occupied.ask_success.body"
        },
        "ask_fail": {
          "type": "outcome",
          "delta": {
            "energy": -3,
            "san": 5
          },
          "title_key": "event.gym_equipment_occupied.ask_fail.title",
          "body_key": "event.gym_equipment_occupied.ask_fail.body"
        },
        "change_check": {
          "type": "check",
          "conditions": [
            {
              "kind": "stat",
              "stat": "academic",
              "op": ">=",
              "value": 30
            }
          ],
          "require": "all",
          "then": "change_success",
          "else": "change_fail"
        },
        "change_success": {
          "type": "outcome",
          "delta": {
            "energy": -10,
            "academic": 2
          },
          "title_key": "event.gym_equipment_occupied.change_success.title",
          "body_key": "event.gym_equipment_occupied.change_success.body"
        },
        "change_fail": {
          "type": "outcome",
          "delta": {
            "energy": -3,
            "san": 5
          },
          "title_key": "event.gym_equipment_occupied.change_fail.title",
          "body_key": "event.gym_equipment_occupied.change_fail.body"
        },
        "wait": {
          "type": "outcome",
          "delta": {
            "san": 5,
            "energy": -3
          },
          "title_key": "event.gym_equipment_occupied.wait.title",
          "body_key": "event.gym_equipment_occupied.wait.body"
        },
        "leave": {
          "type": "outcome",
          "delta": {
            "san": 2
          },
          "title_key": "event.gym_equipment_occupied.leave.title",
          "body_key": "event.gym_equipment_occupied.leave.body"
        }
      }
    }
  ]
}
