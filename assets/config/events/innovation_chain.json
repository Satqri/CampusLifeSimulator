    {
      "id": "innovation_notice",
      "trigger": {
        "type": "interaction",
        "action_id": "campus_bulletin",
        "once": true,
        "conditions": [
          {
            "kind": "group",
            "require": "any",
            "conditions": [
              {
                "kind": "stat",
                "stat": "innovationStage",
                "op": "eq",
                "value": 0
              },
              {
                "kind": "stat",
                "stat": "innovationStage",
                "op": "eq",
                "value": false
