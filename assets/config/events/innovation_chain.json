          "body_key": "event.innovation_notice.intro.body"
        },
        "decide": {
          "type": "choice",
          "options": [
            {
              "then": "sign_up",
              "text_key": "event.innovation_notice.decide.option1"
            },
            {
              "then": "gather_intel_check",
              "text_key": "event.innovation_notice.decide.option2"
            },
            {
              "then": "give_up_innovation",
              "text_key": "event.innovation_notice.decide.option3"
            }
          ],
          "title_key": "event.innovation_notice.decide.title",
          "body_key": "event.innovation_notice.decide.body"
        },
        "sign_up": {
          "type": "outcome",
          "delta": {
            "san": 5,
            "energy": -2
          },
          "hidden_delta": {
            "innovationJoined": true,
            "innovationStage": 1
          },
