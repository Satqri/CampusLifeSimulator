{
  "events": [
    {
      "id": "club_recruitment",
      "trigger": {
        "type": "interaction",
        "action_id": "campus_square",
        "once": true,
        "conditions": [
          {
            "kind": "stat",
            "stat": "clubStage",
            "op": "eq",
            "value": 0
          }
        ],
        "require": "all"
      },
      "root": "intro",
      "steps": {
        "intro": {
          "type": "display",
          "then": "decide",
          "title_key": "event.club_recruitment.intro.title",
          "body_key": "event.club_recruitment.intro.body"
        },
        "decide": {
          "type": "choice",
          "options": [
            {
              "then": "join_academic_check",
              "text_key": "event.club_recruitment.decide.option1"
            },
            {
              "then": "join_sports_check",
              "text_key": "event.club_recruitment.decide.option2"
            },
            {
              "then": "join_arts_check",
              "text_key": "event.club_recruitment.decide.option3"
            },
            {
              "then": "join_none",
              "text_key": "event.club_recruitment.decide.option4"
            }
          ],
          "title_key": "event.club_recruitment.decide.title",
          "body_key": "event.club_recruitment.decide.body"
        },
        "join_academic_check": {
          "type": "check",
          "conditions": [
            {
              "kind": "stat",
              "stat": "academic",
              "op": ">=",
              "value": 30
            }
          ],
          "require": "all",
          "then": "join_academic_success",
          "else": "join_academic_fail"
        },
        "join_academic_success": {
          "type": "outcome",
          "delta": {
            "academic": 5,
            "energy": -5
          },
          "hidden_delta": {
            "clubType": "academic",
            "clubActivityCount": 1,
            "clubRelation": 1,
            "clubStage": 1
          },
          "title_key": "event.club_recruitment.join_academic_success.title",
          "body_key": "event.club_recruitment.join_academic_success.body"
        },
        "join_academic_fail": {
          "type": "outcome",
          "delta": {
            "san": 3
          },
          "hidden_delta": {
            "clubType": "none",
            "clubStage": -1
          },
          "title_key": "event.club_recruitment.join_academic_fail.title",
          "body_key": "event.club_recruitment.join_academic_fail.body"
        },
        "join_sports_check": {
          "type": "check",
          "conditions": [
            {
              "kind": "stat",
              "stat": "energy",
              "op": ">=",
              "value": 35
            }
          ],
          "require": "all",
          "then": "join_sports_success",
          "else": "join_sports_fail"
        },
        "join_sports_success": {
          "type": "outcome",
          "delta": {
            "san": -5,
            "energy": -10
          },
          "hidden_delta": {
            "clubType": "sports",
            "clubActivityCount": 1,
            "healthIndex": 2,
            "clubRelation": 1,
            "clubStage": 1
          },
          "title_key": "event.club_recruitment.join_sports_success.title",
          "body_key": "event.club_recruitment.join_sports_success.body"
        },
        "join_sports_fail": {
          "type": "outcome",
          "delta": {
            "san": 5
          },
          "hidden_delta": {
            "clubType": "none",
            "clubStage": -1
          },
          "title_key": "event.club_recruitment.join_sports_fail.title",
          "body_key": "event.club_recruitment.join_sports_fail.body"
        },
        "join_arts_check": {
          "type": "check",
          "conditions": [
            {
              "kind": "stat",
              "stat": "social",
              "op": ">=",
              "value": 30
            }
          ],
          "require": "all",
          "then": "join_arts_success",
          "else": "join_arts_fail"
        },
        "join_arts_success": {
          "type": "outcome",
          "delta": {
            "social": 5,
            "energy": -5
          },
          "hidden_delta": {
            "clubType": "arts",
            "clubActivityCount": 1,
            "clubRelation": 1,
            "clubStage": 1
          },
          "title_key": "event.club_recruitment.join_arts_success.title",
          "body_key": "event.club_recruitment.join_arts_success.body"
        },
        "join_arts_fail": {
          "type": "outcome",
          "delta": {
            "san": 5
          },
          "hidden_delta": {
            "clubType": "none",
            "clubStage": -1
          },
          "title_key": "event.club_recruitment.join_arts_fail.title",
          "body_key": "event.club_recruitment.join_arts_fail.body"
