{
  "version": 3,
  "configurePresets": [
    {
      "name": "vs-vcpkg-local",
      "displayName": "Visual Studio + C:/vcpkg",
      "inherits": "vcpkg",
      "generator": "Visual Studio 17 2022",
      "architecture": {
        "value": "x64",
        "strategy": "external"
      },
      "toolchainFile": "C:/vcpkg/scripts/buildsystems/vcpkg.cmake",
      "binaryDir": "${sourceDir}/out/build/${presetName}",
      "environment": {
        "HTTP_PROXY": "http://127.0.0.1:7897",
        "HTTPS_PROXY": "http://127.0.0.1:7897"
      },
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "Debug"
      }
    }
  ],
  "buildPresets": [
    {
      "name": "vs-vcpkg-local",
      "displayName": "Build Visual Studio + C:/vcpkg",
      "configurePreset": "vs-vcpkg-local",
      "configuration": "Debug"
    }
  ]
}
