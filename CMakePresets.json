{
  "version": 3,
  "configurePresets": [
    {
      "name": "vcpkg",
      "displayName": "vcpkg (cross-platform)",
      "description": "通过 vcpkg manifest 模式自动安装依赖",
      "toolchainFile": "$env{VCPKG_ROOT}/scripts/buildsystems/vcpkg.cmake",
      "cacheVariables": {
        "CMAKE_EXPORT_COMPILE_COMMANDS": "ON"
      }
    },
    {
      "name": "homebrew",
      "displayName": "Homebrew (macOS)",
      "description": "使用 Homebrew 系统安装的包",
      "cacheVariables": {
        "CMAKE_PREFIX_PATH": "/opt/homebrew"
      },
      "condition": {
        "type": "equals",
        "lhs": "${hostSystemName}",
        "rhs": "Darwin"
      }
    }
  ],
  "buildPresets": [
    {
      "name": "vcpkg",
      "configurePreset": "vcpkg"
    },
    {
      "name": "homebrew",
      "configurePreset": "homebrew"
    }
  ]
}
